# =============================================================================
# OMEN X v2.0 - Variables de Entorno
# =============================================================================

# BINANCE TESTNET (para los 7 días de test)
BINANCE_TESTNET_API_KEY=tu_api_key_testnet
BINANCE_TESTNET_SECRET=tu_secret_testnet

# BINANCE REAL (para después de testnet)
BINANCE_API_KEY=tu_api_key_real
BINANCE_SECRET=tu_secret_real

# TELEGRAM (alertas en tiempo real)
TELEGRAM_BOT_TOKEN=tu_bot_token
TELEGRAM_CHAT_ID=tu_chat_id

# Obtener Telegram Bot Token:
# 1. Habla con @BotFather en Telegram
# 2. Envía /newbot
# 3. Sigue las instrucciones
# 4. Copia el token aquí

# Obtener Chat ID:
# 1. Habla con @userinfobot en Telegram
# 2. Te devolverá tu Chat ID
# 3. Cópialo aquí
