        </div>
        <div class="stat-item">
            <div class="stat-number">15+</div>
            <div class="stat-label">Títulos Mundiales</div>
        </div>
        <div class="stat-item">
            <div class="stat-number">50+</div>
            <div class="stat-label">Eventos/Año</div>
        </div>
        <div class="stat-item">
            <div class="stat-number">12+</div>
            <div class="stat-label">Años Exp.</div>
        </div>
        <div class="stat-item">
            <div class="stat-number">8</div>
            <div class="stat-label">Países</div>
        </div>
    </section>

    <!-- Pilotos -->
