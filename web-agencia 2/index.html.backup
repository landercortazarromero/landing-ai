            <!-- Lander Cortazar -->
            <div class="piloto-card" onclick="openModal('lander')">
                <div class="piloto-avatar">
                    <img src="images/lander.jpg" alt="Lander Cortazar" onerror="this.style.display='none'; this.parentElement.innerText='LANDER'; this.parentElement.style.fontSize='1.4rem'; this.parentElement.style.display='flex'; this.parentElement.style.alignItems='center'; this.parentElement.style.justifyContent='center';">
                </div>
                <h3 class="piloto-name">Lander Cortazar</h3>
                <p class="piloto-dorsal">Dorsal: <span>#59</span></p>
                <ul class="piloto-palmares-mini">
                    <li>🏆 Campeón Basque Country Cup GP3 F2 (2023)</li>
                    <li>🏆 Campeón Basque Country Cup GP2 (2025)</li>
                    <li>🏆 Campeón Nacional Offshore GP2 (2025)</li>
